<Window x:Class="DocumentIA.Batch.Views.BatchOutputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Salida completa"
        Height="640"
        Width="940"
        MinHeight="520"
        MinWidth="760"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock x:Name="TitleText"
                       FontSize="18"
                       FontWeight="SemiBold" />
            <TextBlock Text="Doble clic en un registro para abrir esta vista con el JSON completo de salida."
                       Foreground="{StaticResource BrushMuted}"
                       Margin="0,4,0,0" />
        </StackPanel>

        <TextBox x:Name="OutputTextBox"
                 Grid.Row="1"
                 FontFamily="Consolas"
                 FontSize="12"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 IsReadOnly="True" />

        <DockPanel Grid.Row="2" LastChildFill="False" Margin="0,10,0,0">
            <Button Content="Copiar"
                    Click="Copy_Click"
                    DockPanel.Dock="Left" />
            <Button Content="Cerrar"
                    Click="Close_Click"
                    DockPanel.Dock="Right"
                    Margin="8,0,0,0"
                    Background="#334155" />
        </DockPanel>
    </Grid>
</Window>
