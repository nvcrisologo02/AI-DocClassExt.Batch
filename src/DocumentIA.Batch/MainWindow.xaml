<Window x:Class="DocumentIA.Batch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DocumentIA.Batch.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="DocumentIA Batch - Notas Simples"
        Height="820"
        Width="1360"
        MinHeight="700"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        DragOver="Window_DragOver"
        Drop="Window_Drop">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <Style x:Key="KpiCard" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="4,0" />
        </Style>
        <Style x:Key="KpiLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushMuted}" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style x:Key="KpiValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushText}" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="HealthStatusChip" TargetType="Border">
            <Setter Property="Background" Value="#F1F5F9" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="10,3" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="healthy">
                    <Setter Property="Background" Value="#E8F7EE" />
                    <Setter Property="BorderBrush" Value="#86EFAC" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="ok">
                    <Setter Property="Background" Value="#E8F7EE" />
                    <Setter Property="BorderBrush" Value="#86EFAC" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="online">
                    <Setter Property="Background" Value="#E8F7EE" />
                    <Setter Property="BorderBrush" Value="#86EFAC" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="running">
                    <Setter Property="Background" Value="#E8F7EE" />
                    <Setter Property="BorderBrush" Value="#86EFAC" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="degraded">
                    <Setter Property="Background" Value="#FFF7E6" />
                    <Setter Property="BorderBrush" Value="#FCD34D" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="warning">
                    <Setter Property="Background" Value="#FFF7E6" />
                    <Setter Property="BorderBrush" Value="#FCD34D" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="offline">
                    <Setter Property="Background" Value="#FEF2F2" />
                    <Setter Property="BorderBrush" Value="#FCA5A5" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="unhealthy">
                    <Setter Property="Background" Value="#FEF2F2" />
                    <Setter Property="BorderBrush" Value="#FCA5A5" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="error">
                    <Setter Property="Background" Value="#FEF2F2" />
                    <Setter Property="BorderBrush" Value="#FCA5A5" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="HealthStatusChipText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Border}}" Value="healthy">
                    <Setter Property="Foreground" Value="#166534" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Border}}" Value="ok">
                    <Setter Property="Foreground" Value="#166534" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Border}}" Value="online">
                    <Setter Property="Foreground" Value="#166534" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Border}}" Value="running">
                    <Setter Property="Foreground" Value="#166534" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Border}}" Value="degraded">
                    <Setter Property="Foreground" Value="#92400E" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Border}}" Value="warning">
                    <Setter Property="Foreground" Value="#92400E" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Border}}" Value="offline">
                    <Setter Property="Foreground" Value="#991B1B" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Border}}" Value="unhealthy">
                    <Setter Property="Foreground" Value="#991B1B" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Border}}" Value="error">
                    <Setter Property="Foreground" Value="#991B1B" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="10"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="20,18" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="38" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="30" Height="30" CornerRadius="8" Background="#2563EB" VerticalAlignment="Top">
                                <TextBlock Text="D" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="DocumentIA" FontSize="18" FontWeight="Bold" />
                                <TextBlock Text="Batch Processing Center" Foreground="{StaticResource BrushMuted}" FontSize="12" Margin="0,1,0,0" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="18,14">
                    <StackPanel>
                        <TextBlock Text="CONFIGURACIÓN" Foreground="#64748B" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,10" />

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Versión" FontWeight="SemiBold" />
                                <ComboBox ItemsSource="{Binding AvailableTipologias}"
                                          SelectedItem="{Binding SelectedTipologia, Mode=TwoWay}"
                                          Height="32"
                                          Margin="0,4,0,0" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Recargar"
                                    Command="{Binding RefreshTipologiasCommand}"
                                    Margin="8,20,0,0"
                                    Padding="10,4" />
                        </Grid>

                        <TextBlock Text="Número de colas" Foreground="{StaticResource BrushMuted}" />
                        <TextBox Text="{Binding NumeroColas, Mode=TwoWay}" Margin="0,4,0,14" />

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Classification Only" VerticalAlignment="Center" FontWeight="SemiBold" />
                            <CheckBox Grid.Column="1" IsChecked="{Binding ClassificationOnly, Mode=TwoWay}" VerticalAlignment="Center" />
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Ejecutar Integridad" VerticalAlignment="Center" FontWeight="SemiBold" />
                            <CheckBox Grid.Column="1" IsChecked="{Binding EjecutarIntegridad, Mode=TwoWay}" VerticalAlignment="Center" />
                        </Grid>

                        <TextBlock Text="Limit pages" Foreground="{StaticResource BrushMuted}" />
                        <TextBox Text="{Binding MaxPagesForClassificationOnly, Mode=TwoWay}"
                                 Margin="0,4,0,14"
                                 ToolTip="Solo aplica cuando Classification Only está activo. 0 = sin límite." />

                        <TextBlock Text="UMBRALES" Foreground="#64748B" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,10" />

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Sobreescribir umbrales extracción" VerticalAlignment="Center" FontWeight="SemiBold" />
                            <CheckBox Grid.Column="1" IsChecked="{Binding SobreescribirUmbrales, Mode=TwoWay}" VerticalAlignment="Center" />
                        </Grid>

                        <StackPanel Visibility="{Binding SobreescribirUmbrales, Converter={StaticResource BoolToVis}}"
                                    Margin="0,0,0,14">
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="90" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="extraction.umbral (0–1)" VerticalAlignment="Center" FontWeight="SemiBold" />
                                <TextBox Grid.Column="1" Text="{Binding UmbralExtraccion, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         HorizontalAlignment="Right" Width="85" />
                            </Grid>
                            <Grid Margin="0,4,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="90" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="extraction.umbralCompletitud" VerticalAlignment="Center" FontWeight="SemiBold" />
                                <TextBox Grid.Column="1" Text="{Binding UmbralExtraccionCompletitud, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         HorizontalAlignment="Right" Width="85"
                                         ToolTip="Dejar vacío para no aplicar" />
                            </Grid>
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="90" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="extraction.umbralConfianza" VerticalAlignment="Center" FontWeight="SemiBold" />
                                <TextBox Grid.Column="1" Text="{Binding UmbralExtraccionConfianza, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         HorizontalAlignment="Right" Width="85"
                                         ToolTip="Dejar vacío para no aplicar" />
                            </Grid>
                        </StackPanel>

                        <TextBlock Text="AUTOMATIZACIÓN" Foreground="#64748B" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,10" />

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Ejecutar con AssetResolver" VerticalAlignment="Center" FontWeight="SemiBold" />
                            <CheckBox Grid.Column="1" IsChecked="{Binding EjecutarConAssetResolver, Mode=TwoWay}" VerticalAlignment="Center" />
                        </Grid>

                        <StackPanel Visibility="{Binding AssetResolverCamposVisible, Converter={StaticResource BoolToVis}}"
                                    Margin="0,0,0,10">
                            <TextBlock Text="Campos solicitados (separados por coma)" FontWeight="SemiBold" />
                            <TextBlock Text="Vac\u00edo = todos los disponibles" Foreground="#94A3B8" FontSize="10" Margin="0,1,0,3"/>
                            <TextBox Text="{Binding AssetResolverCamposSolicitados, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Ej: DES_TIPO_AAII, COD_TIPO_AAII, DES_MUNICP, COD_PROVNC"
                                     Margin="0,0,0,0" />
                        </StackPanel>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Subir a GDC" VerticalAlignment="Center" FontWeight="SemiBold" />
                            <CheckBox Grid.Column="1" IsChecked="{Binding SubirAGdc, Mode=TwoWay}" VerticalAlignment="Center" />
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Forzar reproceso" VerticalAlignment="Center" FontWeight="SemiBold" />
                                <TextBlock Text="Omite duplicados y reprocesa" Foreground="#94A3B8" FontSize="10" />
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding ForceReprocess, Mode=TwoWay}" VerticalAlignment="Center" />
                        </Grid>

                        <TextBlock Text="PROMPTS" Foreground="#64748B" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,10" />

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Prompting" VerticalAlignment="Center" FontWeight="SemiBold" />
                            <CheckBox Grid.Column="1" IsChecked="{Binding PromptingEnabled, Mode=TwoWay}" VerticalAlignment="Center" />
                        </Grid>

                        <Button Content="Editar prompts"
                                Command="{Binding EditPromptCommand}"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,14"
                                Background="#EFF6FF"
                                BorderBrush="#BFDBFE"
                                Foreground="#2563EB" />

                        <TextBlock Text="HERRAMIENTAS" Foreground="#64748B" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,10" />

                        <TextBlock Text="Backend URL" Foreground="{StaticResource BrushMuted}" />
                        <TextBox Text="{Binding BackendUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,10" />

                        <TextBlock Text="Function Key" Foreground="{StaticResource BrushMuted}" />
                        <TextBox Text="{Binding FunctionKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" />

                        <Button Content="Guardar configuración"
                                Command="{Binding SaveConfigCommand}"
                                HorizontalAlignment="Stretch"
                                Background="#334155"
                                BorderBrush="#1E293B" />
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Padding="18,14" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <TextBlock Text="Procesamiento inteligente" Foreground="{StaticResource BrushMuted}" FontSize="12" HorizontalAlignment="Center" />
                        <TextBlock Text="de documentos a escala" Foreground="{StaticResource BrushMuted}" FontSize="12" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource CardBorder}">
            <TabControl>
                <TabItem Header="Procesamiento">
                    <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="140" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Batch Processing Center" FontSize="28" FontWeight="Bold" />
                        <TextBlock Text="Automatización y validación documental"
                                   Foreground="{StaticResource BrushMuted}"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                    <Button x:Name="SystemHealthBadgeButton"
                            Grid.Column="1"
                            Padding="12,6"
                            VerticalAlignment="Center"
                            BorderThickness="1"
                            Cursor="Hand"
                            Command="{Binding RefreshHealthCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#E9F7EF" />
                                <Setter Property="BorderBrush" Value="#B7E4C7" />
                                <Setter Property="Foreground" Value="#166534" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="14"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSystemOnline}" Value="False">
                                        <Setter Property="Background" Value="#FEF2F2" />
                                        <Setter Property="BorderBrush" Value="#FECACA" />
                                        <Setter Property="Foreground" Value="#B91C1C" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                        <Button.ToolTip>
                            <ToolTip DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                     Placement="Bottom"
                                     StaysOpen="True"
                                     MaxWidth="380"
                                     Focusable="True">
                                <Border Background="White"
                                        BorderBrush="#D7E2EE"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="12">
                                    <StackPanel MinWidth="320">
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Estado del sistema" FontSize="14" FontWeight="Bold" />
                                                <TextBlock Text="{Binding HealthUpdatedAt, StringFormat=Actualizado: {0}}" Foreground="#64748B" FontSize="11" />
                                            </StackPanel>
                                            <Border Grid.Column="1"
                                                    Style="{StaticResource HealthStatusChip}"
                                                    Tag="{Binding HealthAggregate}"
                                                    VerticalAlignment="Top">
                                                <TextBlock Text="{Binding SystemOnlineLabel}" Style="{StaticResource HealthStatusChipText}" />
                                            </Border>
                                        </Grid>

                                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,0,8">
                                            <TextBlock Text="{Binding EffectiveBackendUrl, StringFormat=Endpoint: {0}}"
                                                       Foreground="#475569"
                                                       TextWrapping="Wrap"
                                                       FontSize="11" />
                                        </Border>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Functions" FontWeight="SemiBold" Margin="0,0,8,6" VerticalAlignment="Center" />
                                            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource HealthStatusChip}" Tag="{Binding HealthFunctions}" Margin="0,0,0,6">
                                                <TextBlock Text="{Binding HealthFunctions}" Style="{StaticResource HealthStatusChipText}" />
                                            </Border>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Asset Resolver" FontWeight="SemiBold" Margin="0,0,8,6" VerticalAlignment="Center" />
                                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource HealthStatusChip}" Tag="{Binding HealthAssetResolver}" Margin="0,0,0,6">
                                                <TextBlock Text="{Binding HealthAssetResolver}" Style="{StaticResource HealthStatusChipText}" />
                                            </Border>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="GDC" FontWeight="SemiBold" Margin="0,0,8,6" VerticalAlignment="Center" />
                                            <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource HealthStatusChip}" Tag="{Binding HealthGdc}" Margin="0,0,0,6">
                                                <TextBlock Text="{Binding HealthGdc}" Style="{StaticResource HealthStatusChipText}" />
                                            </Border>

                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Model providers" FontWeight="SemiBold" Margin="0,0,8,0" VerticalAlignment="Center" />
                                            <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource HealthStatusChip}" Tag="{Binding HealthModelProviders}">
                                                <TextBlock Text="{Binding HealthModelProviders}" Style="{StaticResource HealthStatusChipText}" />
                                            </Border>
                                        </Grid>

                                        <Border Margin="0,10,0,0"
                                                Background="#F8FAFC"
                                                BorderBrush="#E2E8F0"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="8">
                                            <StackPanel>
                                                <TextBlock Text="Detalle técnico"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="#475569"
                                                           Margin="0,0,0,6" />
                                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                              MaxHeight="120">
                                                    <TextBlock Text="{Binding HealthRawPayload}"
                                                               Foreground="#64748B"
                                                               FontSize="11"
                                                               TextWrapping="Wrap" />
                                                </ScrollViewer>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </ToolTip>
                        </Button.ToolTip>

                        <TextBlock Text="{Binding SystemOnlineLabel}" FontWeight="SemiBold" />
                    </Button>
                </Grid>

                <Border Grid.Row="1"
                        Margin="0,12,0,12"
                        Background="#F8FAFC"
                        BorderBrush="#BFDBFE"
                        BorderThickness="1"
                        CornerRadius="8"
                        AllowDrop="True"
                        DragOver="Window_DragOver"
                        Drop="Window_Drop">
                    <Grid>
                        <TextBlock Text="Arrastra tus PDFs aquí o pulsa 'Agregar PDFs'"
                                   Foreground="#475569"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Background="{StaticResource BrushSurface}"
                        BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <UniformGrid Columns="6" Grid.Row="0">
                            <Border Style="{StaticResource KpiCard}" BorderBrush="#BFDBFE" BorderThickness="1,1,1,3">
                                <StackPanel>
                                    <TextBlock Text="Total" Style="{StaticResource KpiLabel}" />
                                    <TextBlock Text="{Binding TotalFiles}" Style="{StaticResource KpiValue}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}" BorderBrush="#93C5FD" BorderThickness="1,1,1,3">
                                <StackPanel>
                                    <TextBlock Text="Procesando" Style="{StaticResource KpiLabel}" />
                                    <TextBlock Text="{Binding RunningFiles}" Style="{StaticResource KpiValue}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}" BorderBrush="#86EFAC" BorderThickness="1,1,1,3">
                                <StackPanel>
                                    <TextBlock Text="OK" Style="{StaticResource KpiLabel}" />
                                    <TextBlock Text="{Binding CompletedFiles}" Style="{StaticResource KpiValue}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}" BorderBrush="#FDE68A" BorderThickness="1,1,1,3">
                                <StackPanel>
                                    <TextBlock Text="Revisión" Style="{StaticResource KpiLabel}" />
                                    <TextBlock Text="{Binding RevisionFiles}" Style="{StaticResource KpiValue}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}" BorderBrush="#FCA5A5" BorderThickness="1,1,1,3">
                                <StackPanel>
                                    <TextBlock Text="Errores" Style="{StaticResource KpiLabel}" />
                                    <TextBlock Text="{Binding ErrorFiles}" Style="{StaticResource KpiValue}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}" BorderBrush="#C4B5FD" BorderThickness="1,1,1,3">
                                <StackPanel>
                                    <TextBlock Text="Duración media" Style="{StaticResource KpiLabel}" />
                                    <TextBlock Text="{Binding AverageDurationDisplay}" Style="{StaticResource KpiValue}" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <UniformGrid Grid.Row="1" Columns="6" Margin="0,8,0,0">
                            <Border Style="{StaticResource KpiCard}">
                                <StackPanel>
                                    <TextBlock Text="Éxito" Style="{StaticResource KpiLabel}" />
                                    <TextBlock Text="{Binding SuccessRateDisplay}" FontSize="16" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}">
                                <StackPanel>
                                    <TextBlock Text="Conf. media" Style="{StaticResource KpiLabel}" />
                                    <TextBlock Text="{Binding AverageConfidenceDisplay}" FontSize="16" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}">
                                <StackPanel>
                                    <TextBlock Text="Dur. lote" Style="{StaticResource KpiLabel}" />
                                    <TextBlock Text="{Binding TotalDurationDisplay}" FontSize="16" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}">
                                <StackPanel>
                                    <TextBlock Text="Finalizados" Style="{StaticResource KpiLabel}" />
                                    <TextBlock Text="{Binding FinishedFiles}" FontSize="16" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}">
                                <StackPanel>
                                    <TextBlock Text="Cancelados" Style="{StaticResource KpiLabel}" />
                                    <TextBlock Text="{Binding CanceledFiles}" FontSize="16" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}">
                                <StackPanel>
                                    <TextBlock Text="JSON" Style="{StaticResource KpiLabel}" />
                                    <TextBlock Text="{Binding OutputJsonFiles}" FontSize="16" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </Grid>
                </Border>

                <DataGrid Grid.Row="3"
                          Name="FilesGrid"
                          ItemsSource="{Binding Files}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          BorderBrush="{StaticResource BrushBorder}"
                          BorderThickness="1"
                          HeadersVisibility="Column"
                          IsReadOnly="True"
                          ClipboardCopyMode="IncludeHeader"
                          RowHeaderWidth="0"
                          GridLinesVisibility="Horizontal"
                          MouseDoubleClick="FilesGrid_MouseDoubleClick">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Copiar CorrelationId"
                                      Command="{Binding DataContext.CopyCorrelationIdCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <MenuItem Header="Copiar InstanceId"
                                      Command="{Binding DataContext.CopyInstanceIdCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nombre del archivo" Binding="{Binding FileName}" Width="2.2*" />
                        <DataGridTextColumn Header="Tamaño" Binding="{Binding DisplaySize}" Width="0.8*" />
                        <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="1.1*" />
                        <DataGridTextColumn Header="Actividad" Binding="{Binding ActividadActual}" Width="1.1*" />
                        <DataGridTextColumn Header="Progreso" Binding="{Binding ProgresoActividades}" Width="0.7*" />
                        <DataGridTextColumn Header="Detalle" Binding="{Binding DetalleActividad}" Width="1.5*" />
                        <DataGridTextColumn Header="Calidad" Binding="{Binding EstadoCalidad}" Width="0.8*" />
                        <DataGridTextColumn Header="Confianza" Binding="{Binding ConfidenceDisplay}" Width="0.9*" />
                        <DataGridTextColumn Header="Duración" Binding="{Binding DurationDisplay}" Width="0.8*" />
                        <DataGridTextColumn Header="CorrelationId" Binding="{Binding CorrelationId}" Width="1.8*" />
                        <DataGridTextColumn Header="InstanceId" Binding="{Binding InstanceId}" Width="1.8*" />
                        <DataGridTextColumn Header="Error" Binding="{Binding MensajeError}" Width="2*" />
                        <DataGridTemplateColumn Header="Acción" Width="1.35*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Reintentar"
                                                Command="{Binding DataContext.RetryFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Padding="6,3"
                                                Margin="4,2,0,2"
                                                Background="#0369A1" />
                                        <Button Content="Limpiar"
                                                Command="{Binding DataContext.ClearFileDataCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Padding="6,3"
                                                Margin="4,2,0,2"
                                                Background="#4B5563" />
                                        <Button Content="Eliminar"
                                                Command="{Binding DataContext.RemoveFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Padding="6,3"
                                                Margin="4,2,4,2"
                                                Background="#B91C1C" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="4"
                    Background="#FFFFFF"
                        BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="10"
                        Margin="0,12,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal">
                            <Button Content="Procesar pendientes"
                                Command="{Binding StartProcessingCommand}"
                                Padding="18,8"
                                Background="#2563EB"
                                BorderBrush="#1D4ED8" />
                            <Button Content="Reintentar"
                                Command="{Binding RetryFailedCommand}"
                                Background="#FFFFFF"
                                BorderBrush="#CBD5E1"
                                Foreground="#334155" />
                            <Button Content="Agregar PDFs"
                                Command="{Binding PickFilesCommand}"
                                Background="#FFFFFF"
                                BorderBrush="#CBD5E1"
                                Foreground="#334155" />
                            <Button Content="Limpiar adjuntos"
                                Command="{Binding ClearAllFilesCommand}"
                                Background="#FFFFFF"
                                BorderBrush="#CBD5E1"
                                Foreground="#334155" />
                            <Button Content="Resumen"
                                Command="{Binding ShowBatchSummaryCommand}"
                                Background="#FFFFFF"
                                BorderBrush="#CBD5E1"
                                Foreground="#334155" />
                            </StackPanel>

                            <Border Grid.Column="2"
                                BorderBrush="#CBD5E1"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="4,0"
                                Margin="12,0">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="CSV"
                                    Command="{Binding ExportCsvCommand}"
                                    Background="#FFFFFF"
                                    BorderThickness="0"
                                    Foreground="#4F46E5"
                                    Margin="0" />
                                <Button Content="Excel"
                                    Command="{Binding ExportExcelCommand}"
                                    Background="#FFFFFF"
                                    BorderThickness="0"
                                    Foreground="#4F46E5"
                                    Margin="4,0,0,0" />
                            </StackPanel>
                            </Border>

                            <Button Grid.Column="3"
                                Content="Cancelar"
                                Command="{Binding CancelProcessingCommand}"
                                Background="#DC2626"
                                BorderBrush="#B91C1C" />
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Doble clic en una fila para ver la salida completa"
                                       Foreground="{StaticResource BrushMuted}"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ProcessStatus}"
                                       VerticalAlignment="Center"
                                       TextAlignment="Right"
                                       Foreground="{StaticResource BrushMuted}" />
                        </Grid>
                    </Grid>
                </Border>
                    </Grid>
                </TabItem>
                <TabItem Header="Historial">
                    <local:HistorialView />
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>
