<Window x:Class="DocumentIA.Batch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="DocumentIA Batch - Notas Simples"
        Height="820"
        Width="1360"
        MinHeight="700"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        DragOver="Window_DragOver"
        Drop="Window_Drop">
    <Window.Resources>
        <Style x:Key="KpiCard" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="4,0" />
        </Style>
        <Style x:Key="KpiLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushMuted}" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style x:Key="KpiValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushText}" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="10"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="20,18" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="38" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="30" Height="30" CornerRadius="8" Background="#2563EB" VerticalAlignment="Top">
                                <TextBlock Text="D" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="DocumentIA" FontSize="18" FontWeight="Bold" />
                                <TextBlock Text="Batch Processing Center" Foreground="{StaticResource BrushMuted}" FontSize="12" Margin="0,1,0,0" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="18,14">
                    <StackPanel>
                        <TextBlock Text="CONFIGURACIÓN" Foreground="#64748B" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,10" />

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Versión" FontWeight="SemiBold" />
                                <ComboBox ItemsSource="{Binding AvailableTipologias}"
                                          SelectedItem="{Binding SelectedTipologia, Mode=TwoWay}"
                                          Height="32"
                                          Margin="0,4,0,0" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Recargar"
                                    Command="{Binding RefreshTipologiasCommand}"
                                    Margin="8,20,0,0"
                                    Padding="10,4" />
                        </Grid>

                        <TextBlock Text="Umbral de confianza" Foreground="{StaticResource BrushMuted}" />
                        <TextBox Text="{Binding UmbralConfianza, Mode=TwoWay}" Margin="0,4,0,10" />

                        <TextBlock Text="Número de colas" Foreground="{StaticResource BrushMuted}" />
                        <TextBox Text="{Binding NumeroColas, Mode=TwoWay}" Margin="0,4,0,14" />

                        <TextBlock Text="AUTOMATIZACIÓN" Foreground="#64748B" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,10" />

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Ejecutar con AssetResolver" VerticalAlignment="Center" FontWeight="SemiBold" />
                            <CheckBox Grid.Column="1" IsChecked="{Binding EjecutarConAssetResolver, Mode=TwoWay}" VerticalAlignment="Center" />
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Subir a GDC" VerticalAlignment="Center" FontWeight="SemiBold" />
                            <CheckBox Grid.Column="1" IsChecked="{Binding SubirAGdc, Mode=TwoWay}" VerticalAlignment="Center" />
                        </Grid>

                        <TextBlock Text="PROMPTS" Foreground="#64748B" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,10" />

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Prompting" VerticalAlignment="Center" FontWeight="SemiBold" />
                            <CheckBox Grid.Column="1" IsChecked="{Binding PromptingEnabled, Mode=TwoWay}" VerticalAlignment="Center" />
                        </Grid>

                        <Button Content="Editar prompts"
                                Command="{Binding EditPromptCommand}"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,14"
                                Background="#EFF6FF"
                                BorderBrush="#BFDBFE"
                                Foreground="#2563EB" />

                        <TextBlock Text="HERRAMIENTAS" Foreground="#64748B" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,10" />

                        <TextBlock Text="Backend URL" Foreground="{StaticResource BrushMuted}" />
                        <TextBox Text="{Binding BackendUrl, Mode=TwoWay}" Margin="0,4,0,10" />

                        <TextBlock Text="Function Key" Foreground="{StaticResource BrushMuted}" />
                        <TextBox Text="{Binding FunctionKey, Mode=TwoWay}" Margin="0,4,0,12" />

                        <Button Content="Guardar configuración"
                                Command="{Binding SaveConfigCommand}"
                                HorizontalAlignment="Stretch"
                                Background="#334155"
                                BorderBrush="#1E293B" />
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Padding="18,14" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <TextBlock Text="Procesamiento inteligente" Foreground="{StaticResource BrushMuted}" FontSize="12" HorizontalAlignment="Center" />
                        <TextBlock Text="de documentos a escala" Foreground="{StaticResource BrushMuted}" FontSize="12" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="140" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Batch Processing Center" FontSize="28" FontWeight="Bold" />
                        <TextBlock Text="Automatización y validación documental"
                                   Foreground="{StaticResource BrushMuted}"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Background="#E9F7EF"
                            BorderBrush="#B7E4C7"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="12,6"
                            VerticalAlignment="Center">
                        <TextBlock Text="Sistema online"
                                   Foreground="#166534"
                                   FontWeight="SemiBold" />
                    </Border>
                </Grid>

                <Border Grid.Row="1"
                        Margin="0,12,0,12"
                        Background="#F8FAFC"
                        BorderBrush="#BFDBFE"
                        BorderThickness="1"
                        CornerRadius="8"
                        AllowDrop="True"
                        DragOver="Window_DragOver"
                        Drop="Window_Drop">
                    <Grid>
                        <TextBlock Text="Arrastra tus PDFs aquí o pulsa 'Agregar PDFs'"
                                   Foreground="#475569"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Background="{StaticResource BrushSurface}"
                        BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <UniformGrid Columns="6" Grid.Row="0">
                            <Border Style="{StaticResource KpiCard}" BorderBrush="#BFDBFE" BorderThickness="1,1,1,3">
                                <StackPanel>
                                    <TextBlock Text="Total" Style="{StaticResource KpiLabel}" />
                                    <TextBlock Text="{Binding TotalFiles}" Style="{StaticResource KpiValue}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}" BorderBrush="#93C5FD" BorderThickness="1,1,1,3">
                                <StackPanel>
                                    <TextBlock Text="Procesando" Style="{StaticResource KpiLabel}" />
                                    <TextBlock Text="{Binding RunningFiles}" Style="{StaticResource KpiValue}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}" BorderBrush="#86EFAC" BorderThickness="1,1,1,3">
                                <StackPanel>
                                    <TextBlock Text="OK" Style="{StaticResource KpiLabel}" />
                                    <TextBlock Text="{Binding CompletedFiles}" Style="{StaticResource KpiValue}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}" BorderBrush="#FDE68A" BorderThickness="1,1,1,3">
                                <StackPanel>
                                    <TextBlock Text="Revisión" Style="{StaticResource KpiLabel}" />
                                    <TextBlock Text="{Binding RevisionFiles}" Style="{StaticResource KpiValue}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}" BorderBrush="#FCA5A5" BorderThickness="1,1,1,3">
                                <StackPanel>
                                    <TextBlock Text="Errores" Style="{StaticResource KpiLabel}" />
                                    <TextBlock Text="{Binding ErrorFiles}" Style="{StaticResource KpiValue}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}" BorderBrush="#C4B5FD" BorderThickness="1,1,1,3">
                                <StackPanel>
                                    <TextBlock Text="Duración media" Style="{StaticResource KpiLabel}" />
                                    <TextBlock Text="{Binding AverageDurationDisplay}" Style="{StaticResource KpiValue}" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <UniformGrid Grid.Row="1" Columns="6" Margin="0,8,0,0">
                            <Border Style="{StaticResource KpiCard}">
                                <StackPanel>
                                    <TextBlock Text="Éxito" Style="{StaticResource KpiLabel}" />
                                    <TextBlock Text="{Binding SuccessRateDisplay}" FontSize="16" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}">
                                <StackPanel>
                                    <TextBlock Text="Conf. media" Style="{StaticResource KpiLabel}" />
                                    <TextBlock Text="{Binding AverageConfidenceDisplay}" FontSize="16" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}">
                                <StackPanel>
                                    <TextBlock Text="Dur. lote" Style="{StaticResource KpiLabel}" />
                                    <TextBlock Text="{Binding TotalDurationDisplay}" FontSize="16" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}">
                                <StackPanel>
                                    <TextBlock Text="Finalizados" Style="{StaticResource KpiLabel}" />
                                    <TextBlock Text="{Binding FinishedFiles}" FontSize="16" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}">
                                <StackPanel>
                                    <TextBlock Text="Cancelados" Style="{StaticResource KpiLabel}" />
                                    <TextBlock Text="{Binding CanceledFiles}" FontSize="16" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}">
                                <StackPanel>
                                    <TextBlock Text="JSON" Style="{StaticResource KpiLabel}" />
                                    <TextBlock Text="{Binding OutputJsonFiles}" FontSize="16" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </Grid>
                </Border>

                <DataGrid Grid.Row="3"
                          Name="FilesGrid"
                          ItemsSource="{Binding Files}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          BorderBrush="{StaticResource BrushBorder}"
                          BorderThickness="1"
                          HeadersVisibility="Column"
                          IsReadOnly="True"
                          RowHeaderWidth="0"
                          GridLinesVisibility="Horizontal"
                          MouseDoubleClick="FilesGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nombre del archivo" Binding="{Binding FileName}" Width="2.2*" />
                        <DataGridTextColumn Header="Tamaño" Binding="{Binding DisplaySize}" Width="0.8*" />
                        <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="1.1*" />
                        <DataGridTextColumn Header="Actividad" Binding="{Binding ActividadActual}" Width="1.1*" />
                        <DataGridTextColumn Header="Progreso" Binding="{Binding ProgresoActividades}" Width="0.7*" />
                        <DataGridTextColumn Header="Detalle" Binding="{Binding DetalleActividad}" Width="1.5*" />
                        <DataGridTextColumn Header="Calidad" Binding="{Binding EstadoCalidad}" Width="0.8*" />
                        <DataGridTextColumn Header="Confianza" Binding="{Binding ConfidenceDisplay}" Width="0.9*" />
                        <DataGridTextColumn Header="Duración" Binding="{Binding DurationDisplay}" Width="0.8*" />
                        <DataGridTextColumn Header="CorrelationId" Binding="{Binding CorrelationId}" Width="1.8*" />
                        <DataGridTextColumn Header="InstanceId" Binding="{Binding InstanceId}" Width="1.8*" />
                        <DataGridTextColumn Header="Error" Binding="{Binding MensajeError}" Width="2*" />
                        <DataGridTemplateColumn Header="Acción" Width="1.35*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Reintentar"
                                                Command="{Binding DataContext.RetryFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Padding="6,3"
                                                Margin="4,2,0,2"
                                                Background="#0369A1" />
                                        <Button Content="Limpiar"
                                                Command="{Binding DataContext.ClearFileDataCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Padding="6,3"
                                                Margin="4,2,0,2"
                                                Background="#4B5563" />
                                        <Button Content="Eliminar"
                                                Command="{Binding DataContext.RemoveFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Padding="6,3"
                                                Margin="4,2,4,2"
                                                Background="#B91C1C" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="4"
                    Background="#FFFFFF"
                        BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="10"
                        Margin="0,12,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal">
                            <Button Content="Procesar pendientes"
                                Command="{Binding StartProcessingCommand}"
                                Padding="18,8"
                                Background="#2563EB"
                                BorderBrush="#1D4ED8" />
                            <Button Content="Reintentar"
                                Command="{Binding RetryFailedCommand}"
                                Background="#FFFFFF"
                                BorderBrush="#CBD5E1"
                                Foreground="#334155" />
                            <Button Content="Agregar PDFs"
                                Command="{Binding PickFilesCommand}"
                                Background="#FFFFFF"
                                BorderBrush="#CBD5E1"
                                Foreground="#334155" />
                            <Button Content="Resumen"
                                Command="{Binding ShowBatchSummaryCommand}"
                                Background="#FFFFFF"
                                BorderBrush="#CBD5E1"
                                Foreground="#334155" />
                            </StackPanel>

                            <Border Grid.Column="2"
                                BorderBrush="#CBD5E1"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="4,0"
                                Margin="12,0">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="CSV"
                                    Command="{Binding ExportCsvCommand}"
                                    Background="#FFFFFF"
                                    BorderThickness="0"
                                    Foreground="#4F46E5"
                                    Margin="0" />
                                <Button Content="Excel"
                                    Command="{Binding ExportExcelCommand}"
                                    Background="#FFFFFF"
                                    BorderThickness="0"
                                    Foreground="#4F46E5"
                                    Margin="4,0,0,0" />
                            </StackPanel>
                            </Border>

                            <Button Grid.Column="3"
                                Content="Cancelar"
                                Command="{Binding CancelProcessingCommand}"
                                Background="#DC2626"
                                BorderBrush="#B91C1C" />
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Doble clic en una fila para ver la salida completa"
                                       Foreground="{StaticResource BrushMuted}"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ProcessStatus}"
                                       VerticalAlignment="Center"
                                       TextAlignment="Right"
                                       Foreground="{StaticResource BrushMuted}" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
